{
  "name": "whatsapp-ai-crm",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "dev:api": "turbo dev --filter=api",
    "dev:whatsapp": "turbo dev --filter=whatsapp",
    "dev:worker": "turbo dev --filter=worker",
    "dev:dashboard": "turbo dev --filter=dashboard",
    "db:migrate": "turbo db:migrate --filter=@wacrm/database",
    "db:seed": "turbo db:seed --filter=@wacrm/database",
    "db:studio": "turbo db:studio --filter=@wacrm/database",
    "db:generate": "turbo db:generate --filter=@wacrm/database",
    "db:push": "turbo db:push --filter=@wacrm/database"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.5.0",
    "turbo": "^2.5.0",
    "typescript": "^6.0.2"
  },
  "pnpm": {
    "overrides": {
      "multer": "^2.0.0",
      "lodash": "^4.17.21",
      "picomatch": "^4.0.0",
      "glob": "^10.4.0"
    }
  }
}
