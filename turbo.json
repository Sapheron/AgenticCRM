{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": ["DATABASE_URL", "DIRECT_DATABASE_URL"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "outputs": []
    },
    "type-check": {
      "outputs": []
    },
    "test": {
      "outputs": ["coverage/**"],
      "dependsOn": ["^build"]
    },
    "db:migrate": {
      "cache": false,
      "env": ["DATABASE_URL", "DIRECT_DATABASE_URL"]
    },
    "db:seed": {
      "cache": false,
      "env": ["DATABASE_URL"]
    },
    "db:studio": {
      "cache": false,
      "persistent": true
    },
    "db:generate": {
      "outputs": ["node_modules/.prisma/**"]
    },
    "db:push": {
      "cache": false,
      "env": ["DATABASE_URL", "DIRECT_DATABASE_URL"]
    }
  }
}
